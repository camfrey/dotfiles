{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
#!/usr/bin/env bash

{{- if eq .chezmoi.os "linux" }}
{{- if eq .chezmoi.osRelease.id "ubuntu" }}
apt_packages=(
    fzf
    zsh
)

sudo apt update
sudo apt upgrade

for pkg in "${apt_packages[@]}"; do
    if dpkg -s "$pkg" &> /dev/null; then
        echo "$pkg is already installed."
    else
        echo "Installing apt package: $pkg"
        sudo apt install "$pkg"
    fi
done
{{- end }}
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
BREW_PACKAGES_FILE="{{ .chezmoi.sourceDir }}/brew-packages.txt"

if [[ -f "$BREW_PACKAGES_FILE" ]]; then
    while IFS= read -r pkg; do
        if [[ -z "${pkg//[[:space:]]/}" ]]; then
            continue
        fi

        if brew list "$pkg" &> /dev/null; then
            echo "$pkg is already installed."
        else
            echo "Installing brew package: $pkg"
            brew install "$pkg"
        fi
    done < "$BREW_PACKAGES_FILE"
fi
{{- end }}

DESIRED_SHELL="$(command -v zsh)"

if [[ -z "${SHELL:-}" || "$SHELL" != "$DESIRED_SHELL" ]]; then
    chsh -s "$DESIRED_SHELL"
fi

if ! command -v cargo &> /dev/null; then
    echo "Rust not found. Installing rustup..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source "$HOME/.cargo/env"
fi

CARGO_PACKAGES_FILE="{{ .chezmoi.sourceDir }}/cargo-packages.txt"

if [[ ! -f "$CARGO_PACKAGES_FILE" ]]; then
    echo "Cargo packages file not found: $CARGO_PACKAGES_FILE"
    exit 1
fi

INSTALLED_LIST=$(cargo install --list)

while IFS= read -r pkg; do
    if [[ -z "${pkg//[[:space:]]/}" ]]; then
        continue
    fi

    # Check if the package name appears at the start of a line in the list
    if echo "$INSTALLED_LIST" | grep -q "^$pkg "; then
        echo "$pkg is already installed."
    else
        echo "Installing $pkg..."
        cargo install "$pkg"
    fi
done < "$CARGO_PACKAGES_FILE"

echo "Running global update..."
cargo install-update -a
{{- end }}
