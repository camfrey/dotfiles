{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash

if ! command -v cargo &> /dev/null; then
    echo "Rust not found. Installing rustup..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source "$HOME/.cargo/env"
fi

CARGO_PACKAGES_FILE="{{ .chezmoi.sourceDir }}/cargo-packages.txt"

if [[ ! -f "$CARGO_PACKAGES_FILE" ]]; then
    echo "Cargo packages file not found: $CARGO_PACKAGES_FILE"
    exit 1
fi

INSTALLED_LIST=$(cargo install --list)

while IFS= read -r pkg; do
    if [[ -z "${pkg//[[:space:]]/}" ]]; then
        continue
    fi

    # Check if the package name appears at the start of a line in the list
    if echo "$INSTALLED_LIST" | grep -q "^$pkg "; then
        echo "$pkg is already installed."
    else
        echo "Installing $pkg..."
        cargo install "$pkg"
    fi
done < "$CARGO_PACKAGES_FILE"

echo "Running global update..."
cargo install-update -a
{{- end }}
