{{- if eq .chezmoi.os "windows" -}}
if (!(Get-Command scoop -ErrorAction SilentlyContinue)) {
    Write-Host "Scoop not found. Installing Scoop..."
    Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser
    Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression
    # Refresh path for scoop
    $env:Path = [System.Environment]::GetEnvironmentVariable("Path", "User") + ";" + [System.Environment]::GetEnvironmentVariable("Path", "Machine")
}

Write-Host "Checking scoop buckets..."
$buckets = @(
    @{ Name = "extras" },
    @{ Name = "nerd-fonts" },
    @{ Name = "java" },
    @{ Name = "abyss"; URL = "https://github.com/abgox/abyss" }
)
foreach ($bucket in $buckets) {
    if (!(scoop bucket list | Select-String $bucket.Name)) {
        Write-Host "Adding Scoop bucket: $($bucket.Name)"
        if ($bucket.URL) {
            scoop bucket add $bucket.Name $bucket.URL
        } else {
            scoop bucket add $bucket.Name
        }
    }
}

Write-Host "Checking scoop packages..."
$scoopPackages = @(
    "7zip",
    "abgox.PSCompletions",
    "carapace-bin",
    "fd",
    "fzf",
    "git",
    "helix",
    "neovim",
    "pwsh",
    "ripgrep",
    "rustup",
    "starship",
    "sudo",
    "wezterm"
)
$installedScoopList = scoop list | Out-String
foreach ($pkg in $scoopPackages) {
    if ($installedScoopList -notmatch "(?m)^$([regex]::Escape($pkg))\s") {
        Write-Host "Installing Scoop package: $pkg"
        scoop install $pkg
    }
}

Write-Host "Updating scoop packages..."
scoop update -a
scoop cleanup -a

if (!(Get-Command cargo -ErrorAction SilentlyContinue)) {
    Write-Host "Cargo not found. Installing via rustup..."
    rustup default stable
    rustup update
    
    # Manually add cargo to the current session path
    $env:Path += ";$env:USERPROFILE\.cargo\bin"
}

$cargoPackagesFile = Join-Path '{{ .chezmoi.sourceDir }}' 'cargo-packages.txt'
if (!(Test-Path $cargoPackagesFile)) {
    throw "Cargo packages file not found: $cargoPackagesFile"
}

$cargoPackages = Get-Content $cargoPackagesFile | ForEach-Object { $_.Trim() } | Where-Object { $_ }
$installedCargoList = cargo install --list | Out-String
foreach ($pkg in $cargoPackages) {
    if ($installedCargoList -notmatch "(?m)^$([regex]::Escape($pkg))\s") {
        Write-Host "Installing Cargo tool: $pkg"
        cargo install $pkg
    }
}

Write-Host "Updating all cargo binaries..."
cargo install-update -a
cargo cache -a

Write-Host "Installing PowerShell modules..."
$modules = @("CompletionPredictor", "PSCompletions")
foreach ($module in $modules) {
    if (!(Get-Module -ListAvailable $module)) {
        Write-Host "Installing PowerShell module: $module"
        Install-Module -Name $module -Scope CurrentUser -Force -AllowClobber
    }
}
{{- end }}
